# ============================================
# AI测试管理平台 - 环境配置示例
# 复制此文件为 .env 并根据需要修改
# ============================================

# ========== 通用配置 ==========
# 环境模式: development | production | test
NODE_ENV=development
APP_NAME=AI测试管理平台
APP_PORT=3000

# ========== 服务端口配置 ==========
# 前端服务
FRONTEND_PORT=3000
# Mock服务
MOCK_SERVICE_PORT=8020
# 认证服务
AUTH_SERVICE_PORT=8001
# 用户服务
USER_SERVICE_PORT=8002
# 项目服务
PROJECT_SERVICE_PORT=8003
# 仪表盘服务
DASHBOARD_SERVICE_PORT=8004
# 测试用例服务
TESTCASE_SERVICE_PORT=8005
# 缺陷服务
DEFECT_SERVICE_PORT=8006
# 需求服务
REQUIREMENT_SERVICE_PORT=8007
# 策略服务
STRATEGY_SERVICE_PORT=8008
# AI服务
AI_SERVICE_PORT=8009

# ========== 数据库配置 ==========
# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=ai_test_platform
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_ROOT_PASSWORD=root

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ========== 消息队列配置 (RabbitMQ) ==========
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_QUEUE_TEST_TASKS=test.tasks
RABBITMQ_QUEUE_AI_TASKS=ai.tasks
RABBITMQ_QUEUE_REPORTS=reports

# ========== Mock开关 ==========
# 是否使用Mock数据: true | false
USE_MOCK=true
# Mock服务延迟 (毫秒)
MOCK_DELAY_MS=0

# ========== AI配置 ==========
# OpenAI API
OPENAI_API_KEY=your-openai-api-key
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4

# ========== 其他配置 ==========
# JWT密钥
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d
