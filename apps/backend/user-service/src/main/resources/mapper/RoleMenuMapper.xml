<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aitest.user.mapper.RoleMenuMapper">

    <!-- 批量插入角色菜单关联 -->
    <insert id="batchInsert" parameterType="map">
        INSERT INTO role_menu (role_id, menu_id, created_at)
        VALUES
        <foreach collection="menuIds" item="menuId" separator=",">
            (#{roleId}, #{menuId}, NOW())
        </foreach>
    </insert>

    <!-- 根据角色ID删除 -->
    <delete id="deleteByRoleId" parameterType="java.lang.Long">
        DELETE FROM role_menu WHERE role_id = #{roleId}
    </delete>

    <!-- 根据角色ID查询菜单ID列表 -->
    <select id="selectMenuIdsByRoleId" parameterType="java.lang.Long" resultType="java.lang.Long">
        SELECT menu_id FROM role_menu WHERE role_id = #{roleId}
    </select>

</mapper>
